.tcard-quote{font-size:16px;font-weight:700;color:#111;line-height:1.5;font-style:italic}
.tcard-quote::before{content:'\201C';font-family:'Georgia','Times New Roman',serif;font-weight:400;font-size:64px;color:var(--lime);line-height:.7;display:block;margin-bottom:8px}
.tcard-desc{font-size:14px;color:rgba(0,0,0,.55);line-height:1.75}
.tcard-rag-label{font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#bbb;margin-top:4px;margin-bottom:8px}
.tcard-metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#e8e8e8;border:1.5px solid #e8e8e8;border-radius:8px;overflow:hidden}
.tcard-metric{background:#f7f7f7;padding:14px 8px;text-align:center}
.tcard-metric-n{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:16px;color:#111;letter-spacing:-.3px;line-height:1}
.tcard-metric-d{font-size:11px;color:#999;margin-top:3px;line-height:1.3}
.tcard-footer{padding:20px 28px;border-top:1.5px solid #f0f0f0;display:flex;align-items:center;gap:14px}
.tcard-avatar{width:38px;height:38px;border-radius:50%;object-fit:cover;flex-shrink:0}
.tcard-name{font-weight:700;font-size:14px;color:#111;line-height:1.2}
.tcard-role{font-size:12px;color:#aaa;margin-top:1px}
@media(max-width:860px){.tcard-grid{grid-template-columns:1fr}}
</style>

