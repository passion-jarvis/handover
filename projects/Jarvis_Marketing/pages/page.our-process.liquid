{% layout none %}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Our Process | Jarvis VA</title>
<meta name="description" content="Every Jarvis VA is hand-picked, tested, and trained before they ever touch your business. Here's exactly how we do it.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,800&family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --lime:#CAE600;
  --bg:#fff;
  --hero-bg:#0a0a0a;
  --surface:#f7f7f7;
  --border:#e8e8e8;
  --text:#111;
  --muted:rgba(0,0,0,.65);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Manrope',sans-serif;font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;overflow-x:hidden}

/* TOPBAR */
.topbar{background:var(--hero-bg);padding:18px 48px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid rgba(255,255,255,.07)}
.topbar-logo{color:#fff;font-family:'Bricolage Grotesque',sans-serif;font-size:18px;font-weight:800;text-decoration:none;letter-spacing:-.5px}
.topbar-logo span{color:var(--lime)}
.topbar-nav{display:flex;align-items:center;gap:32px}
.topbar-link{font-size:13px;font-weight:600;color:rgba(255,255,255,.5);text-decoration:none;transition:color .15s}
.topbar-link:hover{color:#fff}
.topbar-cta{display:inline-block;background:var(--lime);color:#000;font-size:13px;font-weight:700;padding:10px 22px;border-radius:4px;text-decoration:none;transition:background .15s}
.topbar-cta:hover{background:#b5cc00}

/* HERO */
.hero{background:var(--hero-bg);padding:100px 48px 0;position:relative;overflow:hidden;text-align:center}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 0%,rgba(202,230,0,.1) 0%,transparent 70%);pointer-events:none}
.hero-inner{position:relative;z-index:1;max-width:800px;margin:0 auto;padding-bottom:72px}
.eyebrow{display:inline-block;font-size:11px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--lime);margin-bottom:20px}
.hero h1{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(42px,6vw,78px);line-height:.95;letter-spacing:-3px;color:#fff;margin-bottom:28px}
.hero h1 .h1-top{display:block;font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:.65em;color:rgba(255,255,255,.75);letter-spacing:-1px;margin-bottom:4px}
.hero h1 em{font-family:'Bricolage Grotesque',sans-serif;font-style:normal;font-weight:800;color:var(--lime)}
.hero-body{font-size:17px;line-height:1.8;color:rgba(255,255,255,.72);max-width:600px;margin:0 auto 36px}
.hero-cta-btn{display:inline-block;background:var(--lime);color:#000;font-family:'Bricolage Grotesque',sans-serif;font-size:16px;font-weight:800;padding:18px 40px;border-radius:4px;text-decoration:none;transition:background .15s;letter-spacing:-.3px;margin-bottom:72px}
.hero-cta-btn:hover{background:#b5cc00}

/* HERO TRUST STRIP */
.hero-trust{position:relative;z-index:1;background:rgba(255,255,255,.04);border-top:1px solid rgba(255,255,255,.08);display:grid;grid-template-columns:repeat(3,1fr)}
.hero-trust-item{padding:36px 40px;display:flex;align-items:flex-start;gap:20px;border-right:1px solid rgba(255,255,255,.08)}
.hero-trust-item:last-child{border-right:none}
.hero-trust-icon{width:40px;height:40px;background:rgba(202,230,0,.1);border:1px solid rgba(202,230,0,.2);border-radius:4px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.hero-trust-icon svg{width:18px;height:18px;stroke:var(--lime);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.hero-trust-title{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:14px;color:#fff;letter-spacing:-.2px;margin-bottom:5px;text-transform:uppercase;letter-spacing:.05em}
.hero-trust-body{font-size:13px;color:rgba(255,255,255,.65);line-height:1.65}

.hero-stat-n{font-family:'Bricolage Grotesque',sans-serif;font-size:36px;font-weight:800;color:var(--lime);letter-spacing:-1px;line-height:1}
.hero-stat-d{font-size:12px;color:rgba(255,255,255,.65);margin-top:4px;line-height:1.4}
.hero-stat-divider{width:1px;height:40px;background:rgba(255,255,255,.1)}

/* SECTION WRAPPER */
.section{padding:88px 48px}
.section-inner{max-width:1120px;margin:0 auto}
.section-eyebrow{font-size:11px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--lime);margin-bottom:14px}
.section-headline{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(28px,3.5vw,44px);line-height:1.08;letter-spacing:-1.5px;color:#111;margin-bottom:16px}
.section-headline em{font-family:'Bricolage Grotesque',sans-serif;font-style:normal;font-weight:800;color:var(--lime)}
.section-sub{font-size:16px;color:var(--muted);line-height:1.75;max-width:560px}

/* DARK SECTION */
.dark-section{background:var(--hero-bg);padding:88px 48px;position:relative;overflow:hidden}
.dark-section::before{content:'';position:absolute;top:-300px;right:-200px;width:700px;height:700px;background:radial-gradient(circle,rgba(202,230,0,.05) 0%,transparent 65%);pointer-events:none}
.dark-section .section-headline{color:#fff}
.dark-section .section-sub{color:rgba(255,255,255,.68)}

/* STANDARD GRID */
.standard-grid{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:center}
.standard-grid.reverse .grid-visual{order:-1}

/* QUOTE BLOCK */
.quote-block{background:rgba(202,230,0,.07);border-left:3px solid var(--lime);padding:24px 28px;margin:32px 0}
.quote-block p{font-family:'Manrope',sans-serif;font-style:normal;font-size:18px;color:#fff;line-height:1.65}

/* VETTING STATS ROW */
.vetting-row{display:flex;gap:0;border:1.5px solid rgba(255,255,255,.1);border-radius:4px;overflow:hidden;margin-top:40px}
.vetting-stat{flex:1;padding:28px 32px;border-right:1.5px solid rgba(255,255,255,.1)}
.vetting-stat:last-child{border-right:none}
.vetting-n{font-family:'Bricolage Grotesque',sans-serif;font-size:40px;font-weight:800;color:var(--lime);letter-spacing:-1.5px;line-height:1}
.vetting-d{font-size:13px;color:rgba(255,255,255,.68);margin-top:6px;line-height:1.45}

/* PILLAR GRID */
.pillar-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;background:var(--border);border:1.5px solid var(--border);border-radius:4px;overflow:hidden;margin-top:48px}
.pillar{background:#fff;padding:32px 32px 28px}
.pillar-num{font-family:'Bricolage Grotesque',sans-serif;font-size:11px;font-weight:800;color:var(--lime);letter-spacing:.1em;margin-bottom:12px}
.pillar-title{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:19px;color:#111;letter-spacing:-.3px;margin-bottom:10px}
.pillar-body{font-size:14px;color:var(--muted);line-height:1.75}
.pillar-list{list-style:none;display:flex;flex-direction:column;gap:7px;margin-top:14px}
.pillar-list li{font-size:13.5px;color:#444;display:flex;align-items:flex-start;gap:8px;line-height:1.5}
.pillar-list li::before{content:'→';color:var(--lime);flex-shrink:0;font-size:12px;margin-top:2px}

/* JOURNEY SECTION */
.journey-section{background:#f5f5f5;padding:88px 48px 72px}
.journey-section-inner{max-width:1360px;margin:0 auto}
.journey-head{text-align:center;margin-bottom:56px}

.journey-cards{display:flex;gap:10px;align-items:flex-end;overflow-x:auto;padding-bottom:0;scrollbar-width:none}
.journey-cards::-webkit-scrollbar{display:none}

.j-card{flex:1;min-width:160px;background:#fff;border-radius:10px;overflow:hidden;display:flex;flex-direction:column;border:1.5px solid #e4e4e4;transition:transform .22s ease,box-shadow .22s ease}
.j-card:hover{transform:translateY(-8px);box-shadow:0 20px 48px rgba(0,0,0,.1)}
.j-card.featured{border-color:var(--lime);margin-top:-40px;box-shadow:0 8px 32px rgba(202,230,0,.12)}
.j-card.featured:hover{box-shadow:0 24px 56px rgba(202,230,0,.18);transform:translateY(-8px)}

.j-card-top{background:#0d0d0d;padding:24px 20px 22px;display:flex;flex-direction:column;align-items:flex-start}
.j-card.featured .j-card-top{border-bottom:2px solid var(--lime)}
.j-card.featured .j-icon-box{background:var(--lime);border-color:var(--lime)}
.j-card.featured .j-icon-box svg{stroke:#000}
.j-card-body{padding:20px 20px 22px;display:flex;flex-direction:column;flex:1;background:#fff}

.j-icon-box{width:48px;height:48px;background:rgba(202,230,0,.08);border:1.5px solid rgba(202,230,0,.18);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.j-icon-box svg{width:20px;height:20px;stroke:var(--lime);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}

.j-stage{font-size:10px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--lime);margin-bottom:6px}
.j-title{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:15px;color:#111;letter-spacing:-.3px;line-height:1.25;margin-bottom:8px}
.j-sub{font-family:'Manrope',sans-serif;font-style:normal;font-size:13px;font-weight:500;color:rgba(0,0,0,.55);line-height:1.6;margin-bottom:12px;border-bottom:1px solid #eee;padding-bottom:12px}
.j-list{list-style:none;display:flex;flex-direction:column;gap:6px;flex:1}
.j-list li{font-size:13.5px;color:rgba(0,0,0,.65);display:flex;align-items:flex-start;gap:8px;line-height:1.45}
.j-list li::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--lime);flex-shrink:0;margin-top:5px}
.j-passrate{font-family:'Bricolage Grotesque',sans-serif;font-size:13px;font-weight:800;margin-top:16px;padding-top:12px;border-top:1px solid #eee}
.j-passrate .pct{font-size:17px;letter-spacing:-.5px}
.pct-mid{color:#d97b2a}
.pct-fail{color:#c94f4f}
.pct-pass{color:var(--lime)}
.j-passrate .lbl{font-size:10px;color:rgba(0,0,0,.4);font-weight:600;display:block;margin-top:2px;letter-spacing:.03em}

.journey-result-strip{background:var(--lime);padding:40px 48px;display:flex;align-items:center;justify-content:space-between;gap:32px;max-width:1360px;margin:0 auto;border-radius:8px}
.journey-result-left .jr-eyebrow{font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(0,0,0,.62);margin-bottom:8px}
.journey-result-left .jr-headline{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(18px,2vw,26px);color:#000;letter-spacing:-.6px;line-height:1.2}
.journey-result-left .jr-sub{font-size:13.5px;color:rgba(0,0,0,.68);line-height:1.65;margin-top:8px;max-width:520px}
.journey-result-right{text-align:right;flex-shrink:0}
.jr-n{font-family:'Bricolage Grotesque',sans-serif;font-size:clamp(52px,6vw,80px);font-weight:800;color:#000;letter-spacing:-3px;line-height:1}
.jr-d{font-size:11px;font-weight:700;color:rgba(0,0,0,.62);text-transform:uppercase;letter-spacing:.1em;margin-top:4px}

/* LIVE ASSESSMENT CHECKLIST */
.checklist-section{background:var(--hero-bg);padding:88px 48px;position:relative;overflow:hidden}
.checklist-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 50% 50%,rgba(202,230,0,.04) 0%,transparent 70%);pointer-events:none}
.checklist-inner{max-width:1120px;margin:0 auto;position:relative;z-index:1}
.checklist-head{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:end;margin-bottom:56px}
.checklist-head-right{display:flex;flex-direction:column;gap:12px}
.cl-stat{display:flex;align-items:baseline;gap:10px;padding:18px 0;border-bottom:1px solid rgba(255,255,255,.07)}
.cl-stat:first-child{border-top:1px solid rgba(255,255,255,.07)}
.cl-stat-n{font-family:'Bricolage Grotesque',sans-serif;font-size:28px;font-weight:800;color:var(--lime);letter-spacing:-1px;line-height:1;flex-shrink:0}
.cl-stat-d{font-size:13px;color:rgba(255,255,255,.68);line-height:1.5}

.checklist-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
.cl-card{background:#fff;border:1.5px solid #e4e4e4;border-radius:8px;overflow:hidden;display:flex;flex-direction:column;text-align:center;transition:transform .22s ease,box-shadow .22s ease}
.cl-card:hover{transform:translateY(-6px);box-shadow:0 16px 36px rgba(0,0,0,.1)}
.cl-card-top{background:#0d0d0d;padding:24px 20px 20px;display:flex;flex-direction:column;align-items:center;position:relative}
.cl-card-body{padding:14px 16px 18px;background:#fff;display:flex;align-items:center;justify-content:center}
.cl-check{position:absolute;top:10px;right:10px;width:18px;height:18px;background:rgba(202,230,0,.15);border:1px solid rgba(202,230,0,.3);border-radius:3px;display:flex;align-items:center;justify-content:center}
.cl-check svg{width:9px;height:9px;stroke:var(--lime);fill:none;stroke-width:2.5;stroke-linecap:round;stroke-linejoin:round}
.cl-icon{width:48px;height:48px;background:rgba(202,230,0,.08);border:1px solid rgba(202,230,0,.18);border-radius:8px;display:flex;align-items:center;justify-content:center}
.cl-icon svg{width:20px;height:20px;stroke:var(--lime);fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round}
.cl-label{font-size:14px;font-weight:700;color:#111;line-height:1.35}

/* WHAT WE LOOK FOR */
.look-section{background:#fff;padding:88px 48px}
.look-section-inner{max-width:1120px;margin:0 auto}
.look-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--border);border:1.5px solid var(--border);margin-top:52px}
.look-card{background:#fff;padding:44px 44px 40px}
.look-icon{width:44px;height:44px;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;margin-bottom:24px}
.look-icon svg{width:20px;height:20px;stroke:var(--lime);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.look-title{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:13px;letter-spacing:.2em;text-transform:uppercase;color:#111;margin-bottom:20px;padding-bottom:16px;border-bottom:1.5px solid var(--border)}
.look-list{list-style:none;display:flex;flex-direction:column;gap:10px}
.look-list li{font-size:14.5px;color:rgba(0,0,0,.6);display:flex;align-items:flex-start;gap:12px;line-height:1.55}
.look-list li::before{content:'→';color:var(--lime);flex-shrink:0;font-size:13px;margin-top:1px;font-weight:700}

@media(max-width:1100px){
  .j-card{min-width:200px}
}
@media(max-width:860px){
  .checklist-head{grid-template-columns:1fr}
  .checklist-grid{grid-template-columns:repeat(2,1fr)}
  .look-grid{grid-template-columns:1fr}
  .look-card{padding:32px 28px}
  .journey-section{padding:60px 24px 0}
  .journey-cards{flex-direction:column;overflow-x:visible}
  .j-card{min-width:unset}
  .j-card.featured{margin-top:0;box-shadow:none}
  .journey-result-strip{flex-direction:column;text-align:left;padding:32px 24px}
  .journey-result-right{text-align:left}
}

/* DARK PILLAR GRID */
.dark-pillar-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2px;background:rgba(255,255,255,.06);border:1.5px solid rgba(255,255,255,.08);border-radius:4px;overflow:hidden;margin-top:48px}
.dark-pillar{background:var(--hero-bg);padding:32px 32px 28px}
.dark-pillar-num{font-family:'Bricolage Grotesque',sans-serif;font-size:11px;font-weight:800;color:var(--lime);letter-spacing:.1em;margin-bottom:12px}
.dark-pillar-title{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:19px;color:#fff;letter-spacing:-.3px;margin-bottom:10px}
.dark-pillar-body{font-size:14px;color:rgba(255,255,255,.68);line-height:1.75}

/* PROCESS TIMELINE */
.process-timeline{margin-top:56px;display:flex;flex-direction:column;gap:0;border:1.5px solid var(--border);border-radius:4px;overflow:hidden}
.timeline-row{display:grid;grid-template-columns:160px 1fr;border-bottom:1.5px solid var(--border)}
.timeline-row:last-child{border-bottom:none}
.timeline-left{padding:28px 32px;background:var(--hero-bg);display:flex;flex-direction:column;justify-content:flex-start;gap:6px}
.timeline-tag{font-family:'Bricolage Grotesque',sans-serif;font-size:13px;font-weight:800;color:var(--lime);letter-spacing:-.3px}
.timeline-label{font-size:11px;color:rgba(255,255,255,.6);font-weight:600;letter-spacing:.05em}
.timeline-right{padding:28px 36px;background:#fff;display:flex;flex-direction:column;gap:6px}
.timeline-title{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:17px;color:#111;letter-spacing:-.3px}
.timeline-body{font-size:14px;color:var(--muted);line-height:1.7}

/* GUARANTEE STRIP */
.guarantee-strip{background:var(--surface);border:1.5px solid var(--border);border-radius:4px;display:grid;grid-template-columns:repeat(3,1fr);overflow:hidden;margin-top:56px}
.guarantee-item{padding:32px 32px 28px;border-right:1.5px solid var(--border)}
.guarantee-item:last-child{border-right:none}
.guarantee-title{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:17px;color:#111;letter-spacing:-.3px;margin-bottom:8px}
.guarantee-body{font-size:14px;color:var(--muted);line-height:1.7}
.guarantee-badge{display:inline-block;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;background:var(--lime);color:#000;padding:3px 9px;border-radius:2px;margin-bottom:12px}

/* TESTIMONIALS */
.testimonial-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
.testimonial-card{background:var(--surface);border:1.5px solid var(--border);border-radius:4px;padding:28px 28px 24px}
.testimonial-stars{color:var(--lime);font-size:13px;margin-bottom:12px;letter-spacing:2px}
.testimonial-body{font-size:14.5px;color:#333;line-height:1.75;margin-bottom:20px}
.testimonial-author{font-size:13px;font-weight:700;color:#111}
.testimonial-role{font-size:12px;color:#aaa;margin-top:2px}

/* FINAL CTA */
.final-cta{background:var(--hero-bg);padding:100px 48px;text-align:center;position:relative;overflow:hidden}
.final-cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 50% 100%,rgba(202,230,0,.08) 0%,transparent 70%);pointer-events:none}
.final-cta-inner{position:relative;z-index:1;max-width:640px;margin:0 auto}
.final-cta h2{font-family:'Bricolage Grotesque',sans-serif;font-weight:800;font-size:clamp(32px,4vw,52px);color:#fff;line-height:1.05;letter-spacing:-1.5px;margin-bottom:16px}
.final-cta h2 em{font-family:'Bricolage Grotesque',sans-serif;font-style:normal;font-weight:800;color:var(--lime)}
.final-cta p{font-size:16px;color:rgba(255,255,255,.7);max-width:440px;margin:0 auto 36px;line-height:1.7}
.btn-primary{display:inline-block;background:var(--lime);color:#000;font-family:'Bricolage Grotesque',sans-serif;font-size:15px;font-weight:800;padding:18px 36px;border-radius:4px;text-decoration:none;transition:background .15s;letter-spacing:-.2px}
.btn-primary:hover{background:#b5cc00}
.final-note{font-size:13px;color:rgba(255,255,255,.5);margin-top:16px}

@media(max-width:860px){
  .topbar-nav{display:none}
  .standard-grid{grid-template-columns:1fr;gap:40px}
  .pillar-grid,.dark-pillar-grid{grid-template-columns:1fr}
  .vetting-row{flex-direction:column}
  .vetting-stat{border-right:none;border-bottom:1.5px solid rgba(255,255,255,.1)}
  .vetting-stat:last-child{border-bottom:none}
  .testimonial-grid{grid-template-columns:1fr}
  .guarantee-strip{grid-template-columns:1fr}
  .guarantee-item{border-right:none;border-bottom:1.5px solid var(--border)}
  .guarantee-item:last-child{border-bottom:none}
  .timeline-row{grid-template-columns:1fr}
  .timeline-left{padding:20px 24px}
  .timeline-right{padding:20px 24px}
  .section{padding:60px 24px}
  .dark-section{padding:60px 24px}
  .hero{padding:72px 24px 0}
  .hero-inner{padding-bottom:48px}
  .hero-trust{grid-template-columns:1fr}
  .hero-trust-item{border-right:none;border-bottom:1px solid rgba(255,255,255,.08)}
  .hero-trust-item:last-child{border-bottom:none}
  .hero-stat-divider{display:none}
  .topbar{padding:16px 24px}
  .final-cta{padding:72px 24px}
