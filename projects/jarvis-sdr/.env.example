# === SCRAPING ===
SERPAPI_KEY=
PROXYCURL_KEY=
APIFY_KEY=

# === ENRICHMENT ===
APOLLO_KEY=
HUNTER_KEY=

# === GHL ===
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_PIPELINE_ID=
GHL_STAGE_ID_NEW=                 # "Job Signal — New" stage ID
GHL_CF_JOB_TITLE=                 # Custom field key for job title
GHL_CF_JOB_URL=                   # Custom field key for job URL
GHL_CF_JOB_POST_DATE=             # Custom field key for post date
GHL_CF_KEYWORD_CATEGORY=          # Custom field key for keyword category
GHL_CF_EMPLOYEE_COUNT=            # Custom field key for employee count
GHL_CF_REVENUE_ESTIMATE=          # Custom field key for revenue estimate
GHL_CF_ENRICHMENT_STATUS=         # Custom field key for enrichment status

# === SUPABASE (dedup store) ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# === GOOGLE SHEETS (fallback) ===
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=Leads
# Service account JSON path (download from GCP)
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json

# === SLACK ===
SLACK_WEBHOOK_URL=
SLACK_DIGEST_EMAIL=               # Optional: email for daily digest

# === PIPELINE CONFIG ===
MAX_RESULTS_PER_KEYWORD=50        # Per source per keyword per run
DEDUP_WINDOW_DAYS=30
DRY_RUN=false                     # Set true to skip GHL writes during testing
